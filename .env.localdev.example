# Local host-process development on the Mac.
# Copy to .env.localdev and edit the path/password lines.

POSTGRES_USER=vocabapp
POSTGRES_PASSWORD=devpassword
POSTGRES_PORT=5432
DEV_DB_NAME=vocabapp_dev_full

DATABASE_URL=postgresql+asyncpg://vocabapp:devpassword@localhost:5432/vocabapp_dev_full
DATABASE_URL_SYNC=postgresql://vocabapp:devpassword@localhost:5432/vocabapp_dev_full

REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

BACKEND_PORT=8000
FRONTEND_PORT=3000
ADMIN_FRONTEND_PORT=3001

ENVIRONMENT=development
DEV_TEST_USERS_ENABLED=true
JWT_SECRET=dev-jwt-secret-change-me
CELERY_QUEUES=default,imports
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

AUDIO_STORAGE_BACKEND=local
AUDIO_LOCAL_PATH=uploads/audio
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

WORDS_SHARED_DATA_ROOT=/Users/Johnson/words-shared
WORDS_DATA_DIR=/Users/Johnson/words-shared/data
WORDS_VOICE_ROOT=/Users/Johnson/words-shared/voice
