COMPOSE_PROJECT_NAME=words-stack

POSTGRES_USER=vocabapp
POSTGRES_PASSWORD=devpassword
PG_BOOT_DB=postgres
POSTGRES_PORT=5432
REDIS_PORT=6379

DEV_DB_NAME=vocabapp_dev_full
TEST_DB_NAME=vocabapp_test_full
TEST_TEMPLATE_DB_NAME=vocabapp_test_template_full
SMOKE_TEMPLATE_DB_NAME=vocabapp_test_template_smoke

TEST_HOST=YOUR_NUC_HOSTNAME_OR_IP
TEST_PUBLIC_PORT=8088
TEST_ADMIN_PORT=3001
TEST_BACKEND_PORT=8000

ENVIRONMENT=development
DEV_TEST_USERS_ENABLED=true
JWT_SECRET=dev-jwt-secret-change-me
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://YOUR_NUC_HOSTNAME_OR_IP:8088,http://YOUR_NUC_HOSTNAME_OR_IP:3001

WORDS_SHARED_DATA_ROOT=/srv/words-shared
WORDS_DATA_DIR=/srv/words-shared/data
WORDS_VOICE_ROOT=/srv/words-shared/voice
FULL_DUMP_PATH=/srv/words-shared/postgres/dumps/vocabapp_full.dump
