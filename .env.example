# Vocabulary Learning App - Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================
# Database Configuration
# ===========================
POSTGRES_USER=vocabapp
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=vocabapp_dev
POSTGRES_PORT=5432

# Database URLs for application
DATABASE_URL=postgresql+asyncpg://vocabapp:change_this_password_in_production@localhost:5432/vocabapp_dev
DATABASE_URL_SYNC=postgresql://vocabapp:change_this_password_in_production@localhost:5432/vocabapp_dev

# ===========================
# Redis Configuration
# ===========================
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ===========================
# Backend Configuration
# ===========================
BACKEND_PORT=8000
ENVIRONMENT=development  # development, staging, production
SECRET_KEY=your-secret-key-here-generate-a-random-string
JWT_SECRET=your-jwt-secret-here-generate-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
REFRESH_TOKEN_EXPIRATION_DAYS=7

# CORS Settings (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ===========================
# LLM API Keys
# ===========================
# OpenAI
OPENAI_API_KEY=sk-xx-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Default LLM provider (openai, anthropic, custom)
DEFAULT_LLM_PROVIDER=openai

# ===========================
# Lexicon (WordNet + LLM)
# ===========================
# Runtime flags stay here. For the offline/admin lexicon pipeline, use:
#   tools/lexicon/.env.example
#   tools/lexicon/OPERATOR_GUIDE.md
LEXICON_PROVIDER=wordnet
LEXICON_LLM_ENHANCE_ON_LOOKUP=false
# Backward-compatible alias for the offline/admin tool; prefer LEXICON_LLM_BASE_URL in
# the tool-local env example instead of storing admin-only endpoint config in this root file.
LEXICON_LLM_PROVIDER=
LEXICON_LLM_MODEL=
LEXICON_USE_EXTERNAL_FREQUENCY=false

# ===========================
# Text-to-Speech API
# ===========================
# Primary TTS provider fallback (minimax, elevenlabs, google, azure)
TTS_PRIMARY_PROVIDER=minimax

# TTS provider per audio type (allows different providers for different content)
TTS_PROVIDER_WORD=google
TTS_PROVIDER_DEFINITION=google
TTS_PROVIDER_EXAMPLE=azure

# MiniMax TTS
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id
MINIMAX_VOICE_ID=female-tianmei

# ElevenLabs TTS
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_AMERICAN_FEMALE=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_BRITISH_MALE=onwK4e9ZLuTAKqWW03F9

# Google Cloud Text-to-Speech
# Option 1 (Recommended): Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
# Option 2: Base64-encoded service account JSON (for Docker/containers)
# Generate with: base64 -i your-service-account.json | tr -d '\n'
GOOGLE_TTS_CREDENTIALS_BASE64=
# Option 3: Simple API key (limited features, for testing only)
GOOGLE_TTS_API_KEY=

# Microsoft Azure AI Speech
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus

# Audio storage
AUDIO_STORAGE_BACKEND=local
AUDIO_LOCAL_PATH=uploads/audio

# ===========================
# Image Generation API
# ===========================
# DALL-E (OpenAI)
DALLE_API_KEY=sk-your-openai-api-key-here

# Stable Diffusion (if using custom endpoint)
STABLE_DIFFUSION_API_URL=https://your-sd-endpoint.com
STABLE_DIFFUSION_API_KEY=your-sd-api-key

# Default image generation provider (dalle, stable-diffusion)
DEFAULT_IMAGE_PROVIDER=dalle

# ===========================
# Cloud Storage
# ===========================
# AWS S3
AWS_S3_BUCKET=vocabapp-storage
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY=your-s3-access-key
AWS_S3_SECRET_KEY=your-s3-secret-key

# Google Cloud Storage (Alternative)
GCS_BUCKET=vocabapp-storage
GCS_PROJECT_ID=your-project-id
GCS_CREDENTIALS_PATH=/path/to/credentials.json

# Storage provider (s3, gcs, local)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

# CDN URL (optional, for serving media files)
CDN_URL=https://cdn.vocabapp.com

# ===========================
# Email Service (for password reset, etc.)
# ===========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@vocabapp.com

# SendGrid (Alternative)
SENDGRID_API_KEY=your-sendgrid-api-key

# ===========================
# External APIs
# ===========================
# Dictionary API (for word definitions)
OXFORD_API_ID=your-oxford-api-id
OXFORD_API_KEY=your-oxford-api-key

# Merriam-Webster API (Alternative)
MERRIAM_WEBSTER_API_KEY=your-mw-api-key

# Translation API
GOOGLE_TRANSLATE_API_KEY=your-google-translate-key

# ===========================
# Monitoring & Analytics
# ===========================
# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics
GA_TRACKING_ID=UA-XXXXX-Y

# Mixpanel (User Analytics)
MIXPANEL_TOKEN=your-mixpanel-token

# ===========================
# Rate Limiting
# ===========================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# LLM Rate Limiting (to control costs)
LLM_RATE_LIMIT_PER_USER_PER_DAY=100
IMAGE_GEN_RATE_LIMIT_PER_USER_PER_DAY=20

# ===========================
# Development Tools
# ===========================
# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Redis Commander
REDIS_COMMANDER_PORT=8081

# ===========================
# Feature Flags
# ===========================
ENABLE_LLM_FEATURES=true
ENABLE_IMAGE_GENERATION=true
ENABLE_TTS=true
ENABLE_USER_REGISTRATION=true
ENABLE_SOCIAL_FEATURES=false
ENABLE_ANALYTICS=true

# ===========================
# Caching
# ===========================
CACHE_TTL_SECONDS=3600
CACHE_ENABLED=true

# ===========================
# Logging
# ===========================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json, text

# ===========================
# Testing
# ===========================
TEST_DATABASE_URL=postgresql://vocabapp:testpass@localhost:5432/vocabapp_test
PYTEST_SKIP_SLOW=false

# ===========================
# Mobile App Configuration
# ===========================
# iOS
IOS_BUNDLE_ID=com.vocabapp.ios
IOS_APP_STORE_ID=your-app-store-id

# Android
ANDROID_PACKAGE_NAME=com.vocabapp.android
ANDROID_PLAY_STORE_ID=your-play-store-id

# Push Notifications
FIREBASE_SERVER_KEY=your-firebase-server-key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json

# ===========================
# Security
# ===========================
# Password hashing
BCRYPT_ROUNDS=12

# Session
SESSION_TIMEOUT_MINUTES=30

# HTTPS (production)
FORCE_HTTPS=false

# ===========================
# Backup & Maintenance
# ===========================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Cron format: 2 AM daily
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=vocabapp-backups

# ===========================
# Development Overrides
# ===========================
# Skip authentication in development (NOT for production!)
DEV_SKIP_AUTH=false

# Mock LLM responses (to save costs during development)
DEV_MOCK_LLM=false

# Use local file storage instead of cloud
DEV_USE_LOCAL_STORAGE=true
