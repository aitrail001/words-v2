COMPOSE_PROJECT_NAME=words-gate-stack

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=55432
REDIS_PORT=56379

TEST_DB_NAME=words_test


TEST_BACKEND_PORT=18000
TEST_PUBLIC_PORT=18088
TEST_ADMIN_PORT=13001

WORDS_DATA_DIR=./data
TEST_INTERNAL_API_URL=http://backend:8000/api

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/words_test
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/words_test
REDIS_URL=redis://redis:6379/0


ENVIRONMENT=development
DEV_TEST_USERS_ENABLED=true
JWT_SECRET=test-secret
LOG_LEVEL=INFO
CELERY_QUEUES=default,imports
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://frontend:3000,http://admin-frontend:3001

E2E_BASE_URL=http://frontend:3000
E2E_API_URL=http://backend:8000/api
E2E_ADMIN_URL=http://admin-frontend:3001
