# Lexicon admin tool environment example
# Copy this file to `tools/lexicon/.env.local`, then export it before running the CLI:
#   set -a && source tools/lexicon/.env.local && set +a
# This file is for the offline/admin lexicon pipeline, not the runtime app request path.

# Where the lexicon CLI should write snapshots and compiled exports by default.
LEXICON_OUTPUT_ROOT=data/lexicon

# ===========================
# Offline lexical base inputs
# ===========================
# `build-base` requires real WordNet and `wordfreq` dependencies. Install them first:
#   python3 -m pip install -r tools/lexicon/requirements.txt
#   python3 -m nltk.downloader wordnet omw-1.4
# Optional: set `NLTK_DATA` if your corpora live outside the default search path.
# NLTK_DATA=/absolute/path/to/nltk_data

# ===========================
# LLM enrichment endpoint
# ===========================
# Leave these blank if you are only running `build-base`, `validate`, `compile-export`,
# or `import-db --dry-run`.
LEXICON_LLM_BASE_URL=
LEXICON_LLM_MODEL=
LEXICON_LLM_API_KEY=

# Optional transport hint:
# - leave blank for the default Python transport
# - set to `node` for Cloudflare-fronted/custom OpenAI-compatible gateways that work
#   with the official Node SDK but reject the Python transport
LEXICON_LLM_TRANSPORT=

# Backward-compatible alias accepted by the tool, but prefer `LEXICON_LLM_BASE_URL`.
# LEXICON_LLM_PROVIDER=

# ===========================
# Suggested operator values
# ===========================
# Example seed set for quick local smoke runs:
#   run set lead
# Example snapshot dir under `LEXICON_OUTPUT_ROOT`:
#   data/lexicon/snapshots/demo
# Example compiled export path:
#   data/lexicon/snapshots/demo/words.enriched.jsonl

# ===========================
# Local DB import
# ===========================
# Only needed for non-dry-run `import-db` runs.
DATABASE_URL=postgresql+asyncpg://vocabapp:change_this_password_in_production@localhost:5432/vocabapp_dev
DATABASE_URL_SYNC=postgresql://vocabapp:change_this_password_in_production@localhost:5432/vocabapp_dev

# Recommended import metadata values for local/admin runs:
#   --source-type lexicon_snapshot
#   --source-reference lexicon-<date-or-batch-id>
#   --language en

# ===========================
# Custom gateway example
# ===========================
# Example OpenAI-compatible gateway configuration:
# LEXICON_LLM_BASE_URL=https://api.nwai.cc
# LEXICON_LLM_MODEL=gpt-5.1
# LEXICON_LLM_TRANSPORT=node
# Keep the API key in your local `.env.local` only; never commit it.
