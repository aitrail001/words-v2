COMPOSE_PROJECT_NAME=words-ci-stack

POSTGRES_USER=vocabapp
POSTGRES_PASSWORD=change_this_password_in_production
PG_BOOT_DB=postgres
POSTGRES_PORT=15432
REDIS_PORT=16379

DEV_DB_NAME=vocabapp_dev_full
TEST_DB_NAME=vocabapp_test_full
TEST_TEMPLATE_DB_NAME=vocabapp_test_template_full
SMOKE_TEMPLATE_DB_NAME=vocabapp_test_template_smoke

TEST_HOST=localhost
TEST_PUBLIC_PORT=28088
TEST_ADMIN_PORT=23001
TEST_BACKEND_PORT=28000
TEST_INTERNAL_API_URL=http://backend:8000/api

ENVIRONMENT=development
DEV_TEST_USERS_ENABLED=true
JWT_SECRET=test-secret
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://frontend:3000,http://admin-frontend:3001

WORDS_SHARED_DATA_ROOT=.
WORDS_DATA_DIR=./data
WORDS_VOICE_ROOT=./data/lexicon/voice
FULL_DUMP_PATH=./tmp/vocabapp_full.dump
